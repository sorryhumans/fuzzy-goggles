{
  "version": 2,
  "builds": [
    {
      "src": "leadmap/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["leadmap/public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "leadmap/server.js"
    }
  ],
  "functions": {
    "leadmap/server.js": {
      "maxDuration": 60
    }
  }
}
